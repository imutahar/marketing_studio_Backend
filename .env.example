# Server
PORT=3001
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Set to require this shared password (x-app-password header) on all API calls
# except /api/health; leave empty to disable the gate.
APP_PASSWORD=
# Hard daily cap on generations as a cost backstop; in-memory, resets on restart.
MAX_GENERATIONS_PER_DAY=200

# Generation provider: "mock" (default) or "byteplus"
GENERATION_PROVIDER=mock

# ── BytePlus (ModelArk / Seedance) ─────────────────────────────────────────
# Set GENERATION_PROVIDER=byteplus and BYTEPLUS_API_KEY to enable real
# generation. Model ids default to the verified ones below, so the key is the
# only required value. Get the key from https://console.byteplus.com/ark
BYTEPLUS_API_KEY=
# Regional ModelArk base URL (confirm your region in the console)
BYTEPLUS_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3
# Model ids (override only if yours differ)
BYTEPLUS_VIDEO_MODEL=seedance-1-0-pro-fast-251015
BYTEPLUS_IMAGE_MODEL=seedream-5-0-260128
# Image output size (Seedream): 1K | 2K | 4K
BYTEPLUS_IMAGE_SIZE=2K
# Send the selected character/avatar image as a second video reference
# (so it can appear as the presenter). Set to false if the model rejects
# multiple reference images.
BYTEPLUS_INCLUDE_CHARACTER_IMAGE=true

# ── Object storage (Vercel Blob) ───────────────────────────────────────────
# Enables durable Blob storage for generation inputs/outputs (re-hosts merchant
# uploads as public URLs and re-hosts expiring provider outputs). Get it by
# linking a Vercel Blob store to the project. Leave blank to disable (local/dev).
BLOB_READ_WRITE_TOKEN=
