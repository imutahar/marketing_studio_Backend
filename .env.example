# Server
PORT=3001
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Generation provider: "mock" (default) or "byteplus"
GENERATION_PROVIDER=mock

# BytePlus (Seedance) — fill these in and set GENERATION_PROVIDER=byteplus
# to enable real generation.
BYTEPLUS_API_KEY=
BYTEPLUS_ENDPOINT=
BYTEPLUS_VIDEO_MODEL=
BYTEPLUS_IMAGE_MODEL=
