# Server
PORT=3001
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Generation provider: "mock" (default) or "byteplus"
GENERATION_PROVIDER=mock

# ── BytePlus (ModelArk / Seedance) ─────────────────────────────────────────
# Set GENERATION_PROVIDER=byteplus and fill these to enable real generation.
# Get the API key from https://console.byteplus.com/ark
BYTEPLUS_API_KEY=
# Regional ModelArk base URL (confirm your region in the console)
BYTEPLUS_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3
# Model / endpoint ids from your ModelArk console
BYTEPLUS_VIDEO_MODEL=
BYTEPLUS_IMAGE_MODEL=
